---
import { SITE } from '../data/site';
import { localePath, type Lang } from '../i18n/index';
import type { Translations } from '../i18n/en';

const { lang, t } = Astro.props as { lang: Lang; t: Translations };
const p = (path: string) => localePath(lang, path);

const allLangs = ['en', 'fr', 'es', 'nl'] as const;
const currentPath = Astro.url.pathname
  .replace(/^\/(fr|es|nl)/, '')
  .replace(/^$/, '/');
const langLinks: Record<string, string> = {};
for (const l of allLangs) {
  langLinks[l] = l === 'en'
    ? (currentPath || '/')
    : `/${l}${currentPath === '/' ? '/' : currentPath}`;
}
---
<footer class="px-6 py-10" style="background:#1A3333; color:rgba(255,255,255,0.55);">
  <div class="max-w-6xl mx-auto grid gap-10"
       style="grid-template-columns: 1.2fr 1fr 1fr;">

    <div>
      <a href={p('/')}>
        <img src="/images/logo.png" alt="HappyBein" class="h-8 w-auto" />
      </a>
      <p class="mt-3 text-sm leading-relaxed max-w-[260px]">{t.footer.tagline}</p>
    </div>

    <div>
      <h4 class="text-[0.72rem] font-bold tracking-[0.12em] uppercase mb-4" style="color:#2ABFBF;">{t.footer.initiativesTitle}</h4>
      <a href={p('/initiatives')} class="block text-sm mb-2 hover:text-white transition-colors">{t.footer.allInitiatives}</a>
      <a href="https://yeahvibe.com"              target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">YeahVibe ↗</a>
      <a href="https://yeahsight.com"             target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">YeahSight ↗</a>
      <a href="https://yeahdev.com"               target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">YeahDev ↗</a>
      <a href="https://workout.yeahvibe.com"      target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">Workout ↗</a>
      <a href="https://gametrack.yeahvibe.com"    target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">GameTrack ↗</a>
      <a href="https://speaknote.happybein.com"   target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">SpeakNote ↗</a>
      <a href="https://dailytracker.yeahvibe.com" target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">DailyTracker ↗</a>
    </div>

    <div>
      <h4 class="text-[0.72rem] font-bold tracking-[0.12em] uppercase mb-4" style="color:#2ABFBF;">{t.footer.aboutTitle}</h4>
      <a href={p('/manifesto')} class="block text-sm mb-2 hover:text-white transition-colors">{t.footer.manifesto}</a>
      <a href={p('/roadmap')}   class="block text-sm mb-2 hover:text-white transition-colors">{t.footer.roadmap}</a>
      <a href={p('/contact')}   class="block text-sm mb-2 hover:text-white transition-colors">{t.footer.contact}</a>
      <a href="https://form.jotform.com/222551513307043" target="_blank" rel="noopener" class="block text-sm mb-2 hover:text-white transition-colors">{t.footer.feedback}</a>
    </div>

  </div>

  <div class="max-w-6xl mx-auto mt-8 pt-5 flex flex-wrap justify-between items-center gap-3 text-xs"
       style="border-top:1px solid rgba(255,255,255,0.08);">
    <span>{t.footer.copyright}</span>
    <div class="flex gap-3 text-xs">
      {allLangs.map(l => (
        l === lang
          ? <span style="color:#2ABFBF;" class="font-bold">{l.toUpperCase()}</span>
          : <a href={langLinks[l]} class="hover:text-white transition-colors"
               style="color:rgba(255,255,255,0.45);">{l.toUpperCase()}</a>
      ))}
    </div>
    <span class="font-mono-sm" style="color:rgba(255,255,255,0.3);">v{SITE.version} · {SITE.versionDate}</span>
    <div class="flex gap-4">
      <a href={SITE.social.facebook} target="_blank" rel="noopener" class="hover:text-white transition-colors" style="color:rgba(255,255,255,0.45);">Facebook</a>
      <a href={SITE.social.linkedin} target="_blank" rel="noopener" class="hover:text-white transition-colors" style="color:rgba(255,255,255,0.45);">LinkedIn</a>
      <a href={SITE.social.discord}  target="_blank" rel="noopener" class="hover:text-white transition-colors" style="color:rgba(255,255,255,0.45);">Discord</a>
      <a href={SITE.social.twitter}  target="_blank" rel="noopener" class="hover:text-white transition-colors" style="color:rgba(255,255,255,0.45);">Twitter</a>
    </div>
  </div>
</footer>
