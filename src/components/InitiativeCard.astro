---
import type { Initiative } from '../data/initiatives';
import { initiativeTranslations, type Lang } from '../i18n/index';
import type { Translations } from '../i18n/en';

const { initiative: i, lang, t } = Astro.props as {
  initiative: Initiative;
  lang: Lang;
  t: Translations;
};

// Use French translations if available, otherwise fall back to English
const fr = lang === 'fr' ? initiativeTranslations[i.id] : null;
const badge    = fr?.badge    ?? i.badge;
const summary  = fr?.summary  ?? i.summary;
const details  = fr?.details  ?? i.details;
const ctaLabel = fr?.ctaLabel ?? i.ctaLabel;

const ctaHref = i.id === 'happybein'
  ? (lang === 'fr' ? '/fr/manifesto' : '/manifesto')
  : i.externalUrl;
---

<div class="init-card" id={i.id}>
  <div class={`h-[7px] shrink-0 ${i.bannerClass}`}></div>

  <div class="flex flex-col flex-1 p-5 sm:p-6">

    <div class="flex items-center gap-3 mb-3">
      <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0 ${i.iconBgClass}`}>
        {i.icon}
      </div>
      <div>
        <div class="font-display font-black text-ink text-[1.05rem] leading-tight">{i.name}</div>
        <div class="font-mono-sm text-muted mt-[2px]">{i.externalUrl.replace('https://', '')}</div>
      </div>
    </div>

    <span class={`inline-flex items-center gap-1 text-2xs font-bold tracking-widest uppercase px-3 py-1 rounded-full self-start mb-3 ${i.badgeColorClass}`}>
      <span class="w-[6px] h-[6px] rounded-sm inline-block shrink-0" style={`background:${i.dotColor}; animation:pulse 2s infinite;`}></span>
      {badge}
    </span>

    <p class="text-sm text-muted leading-relaxed mb-3">{summary}</p>

    <button
      class={`w-full flex items-center justify-center gap-2 text-[0.8rem] font-display font-bold px-3 py-3 rounded border mb-3 transition-colors ${i.toggleColorClass}`}
      style="min-height:44px; background:transparent;"
      data-toggle={i.id}
      data-readmore={t.initiatives.readMore}
      data-showless={t.initiatives.showLess}
    >
      {t.initiatives.readMore}
    </button>

    <div class="init-details" data-details={i.id}>
      <div class="init-details-inner">
        {details.map((block: any) => (
          block.type === 'italic'
            ? <p class="text-sm text-muted italic mb-3">{block.text}</p>
            : block.type === 'bullets'
              ? <ul class="flex flex-col gap-[0.45rem] mb-3">
                  {block.items.map((item: string) => (
                    <li class="flex items-start gap-2 text-[0.875rem] text-body leading-snug">
                      <span class="w-[6px] h-[6px] rounded-sm shrink-0 mt-[0.42rem]" style={`background:${i.dotColor};`}></span>
                      {item}
                    </li>
                  ))}
                </ul>
              : block.type === 'pillars'
                ? <>
                    <div class="text-2xs font-bold tracking-widest uppercase text-teal-dark mb-2">{t.initiatives.pillarLabel}</div>
                    <ul class="flex flex-col gap-[0.45rem] mb-3">
                      {block.items.map((p2: any) => (
                        <li class="flex items-start gap-2 text-[0.855rem] text-body leading-snug">
                          <span class="font-display font-black text-[0.68rem] text-white rounded-full flex items-center justify-center shrink-0 mt-[2px]"
                                style={`width:17px;height:17px;min-width:17px;background:${i.dotColor};`}>
                            {p2.num}
                          </span>
                          <span><strong>{p2.title}</strong> — {p2.desc}</span>
                        </li>
                      ))}
                    </ul>
                  </>
                : <a href={block.href} target="_blank" rel="noopener"
                     class="inline-flex items-center gap-1 text-[0.8rem] font-semibold px-3 py-[0.3rem] rounded border mb-3"
                     style={`color:${i.dotColor}; border-color:${i.dotColor}33;`}>
                     {block.label}
                   </a>
        ))}
      </div>
    </div>

    <div class="mt-auto pt-3 border-t flex items-center gap-3" style="border-color:rgba(42,191,191,0.18);">
      <a href={ctaHref}
         target={i.id !== 'happybein' ? '_blank' : undefined}
         rel={i.id !== 'happybein' ? 'noopener' : undefined}
         class={`inline-flex items-center gap-1 text-[0.84rem] font-display font-bold min-h-[44px] py-2 ${i.linkColorClass}`}>
        {ctaLabel}
      </a>
      <span class="ml-auto flex items-center gap-1 text-2xs font-bold tracking-wider uppercase text-muted">
        <span class="w-[6px] h-[6px] rounded-sm" style={`background:${i.dotColor}; animation:pulse 2s infinite;`}></span>
        {t.initiatives.live}
      </span>
    </div>

  </div>
</div>

<style>
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
</style>
