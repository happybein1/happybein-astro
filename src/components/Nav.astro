---
import { SITE } from '../data/site';
import { localePath, type Lang } from '../i18n/index';
import type { Translations } from '../i18n/en';

const { lang, t } = Astro.props as { lang: Lang; t: Translations };
const { version, versionDate } = SITE;
const p = (path: string) => localePath(lang, path);
const toggleHref = t.langToggleHref;
const items = SITE.nav.initiatives as any[];
---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center"
     style="height:70px; background:rgba(255,255,255,0.97); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); border-bottom:1px solid rgba(42,191,191,0.18);">
  <div class="max-w-6xl mx-auto px-5 w-full flex items-center justify-between">

    <!-- Logo -->
    <a href={p('/')} class="flex items-center shrink-0">
      <img src="/images/logo.png" alt="HappyBein" class="h-9 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center">

      <!-- Initiatives dropdown -->
      <li class="nav-item relative">
        <a href={p('/initiatives')}
           class="flex items-center gap-1 px-4 py-2 font-display font-bold text-[0.9rem] text-ink hover:text-teal-dark transition-colors">
          {t.nav.initiatives}
          <span class="inline-block w-[7px] h-[7px] border-r-2 border-b-2 border-current rotate-45 translate-y-[-1px]"></span>
        </a>
        <div class="nav-dropdown" style="min-width:260px;">
          {items.map((item: any) => (
            item.bold
              ? <a href={p('/initiatives')}
                   class="block px-5 py-[0.6rem] text-sm font-bold text-teal-dark hover:bg-lightbg whitespace-nowrap">
                   {t.nav.allInitiatives}
                 </a>
              : item.groupLabel
                ? <div class="px-5 pt-3 pb-1 text-[0.65rem] font-bold tracking-[0.13em] uppercase"
                       style="color:#1A9A9A;">
                    {lang === 'fr'
                      ? (item.groupLabel === 'Insights & Tools' ? 'Outils & Insights' : 'Mini Applications')
                      : item.groupLabel}
                  </div>
                : item.divider
                  ? <div class="h-px my-1 mx-3" style="background:rgba(42,191,191,0.18);"></div>
                  : <a href={item.external ? item.href : p(item.href)}
                       target={item.external ? '_blank' : undefined}
                       rel={item.external ? 'noopener' : undefined}
                       class="block pl-8 pr-5 py-[0.55rem] text-sm text-body hover:bg-lightbg hover:text-teal-dark whitespace-nowrap">
                       {item.label}{item.external ? ' ↗' : ''}
                     </a>
          ))}
        </div>
      </li>

      <!-- About dropdown -->
      <li class="nav-item relative">
        <a href={p('/manifesto')}
           class="flex items-center gap-1 px-4 py-2 font-display font-bold text-[0.9rem] text-ink hover:text-teal-dark transition-colors">
          {t.nav.about}
          <span class="inline-block w-[7px] h-[7px] border-r-2 border-b-2 border-current rotate-45 translate-y-[-1px]"></span>
        </a>
        <div class="nav-dropdown">
          <a href={p('/manifesto')} class="block px-5 py-[0.65rem] text-sm text-body hover:bg-lightbg hover:text-teal-dark whitespace-nowrap">{t.nav.manifesto}</a>
          <a href={p('/roadmap')}   class="block px-5 py-[0.65rem] text-sm text-body hover:bg-lightbg hover:text-teal-dark whitespace-nowrap">{t.nav.roadmap}</a>
          <div class="h-px my-1" style="background:rgba(42,191,191,0.18);"></div>
          <a href={p('/contact')}   class="block px-5 py-[0.65rem] text-sm text-body hover:bg-lightbg hover:text-teal-dark whitespace-nowrap">{t.nav.contact}</a>
        </div>
      </li>


      <!-- Language toggles — all 4 shown, active one highlighted differently -->
      <li class="ml-2 flex items-center gap-1">
        {(['en', 'fr', 'es', 'nl'] as const).map(l => {
          const isActive = l === lang;
          // Build equivalent page URL in target language
          const currentPath = Astro.url.pathname
            .replace(/^\/(fr|es|nl)/, '')   // strip current lang prefix
            .replace(/^$/, '/');             // ensure root stays /
          const href = l === 'en'
            ? (currentPath || '/')
            : `/${l}${currentPath === '/' ? '/' : currentPath}`;
          return (
            <a href={href}
               class={`px-3 py-1 rounded-full font-display font-bold text-sm border-2 transition-all ${
                 isActive
                   ? 'bg-teal-DEFAULT border-teal-DEFAULT text-white cursor-default pointer-events-none'
                   : 'border-teal-DEFAULT text-teal-dark hover:bg-teal-DEFAULT hover:text-white'
               }`}>
              {l.toUpperCase()}
            </a>
          );
        })}
      </li>
    </ul>

    <!-- Hamburger -->
    <button id="hamburger" aria-label="Menu"
            class="md:hidden flex flex-col gap-[5px] bg-transparent border-none cursor-pointer"
            style="padding:8px; min-width:44px; min-height:44px; align-items:center; justify-content:center;">
      <span class="block w-6 h-[2px] bg-ink rounded"></span>
      <span class="block w-6 h-[2px] bg-ink rounded"></span>
      <span class="block w-6 h-[2px] bg-ink rounded"></span>
    </button>
  </div>
</nav>

<!-- Version bar -->
<div class="version-bar">
  <span class="text-teal-DEFAULT font-bold font-mono-sm">v{version}</span>
  <span style="color:rgba(255,255,255,0.15);">·</span>
  <span style="color:rgba(255,255,255,0.45);" class="font-mono-sm">{versionDate}</span>
  <span style="color:rgba(255,255,255,0.15);">·</span>
  <span style="color:rgba(255,255,255,0.45);" class="font-mono-sm">{t.versionBar}</span>
</div>

<!-- Mobile nav -->
<div id="mobile-nav"
     class="hidden fixed left-0 right-0 bottom-0 bg-white z-40 overflow-y-auto flex-col px-6 py-4"
     style="top:calc(70px + 22px); -webkit-overflow-scrolling:touch;">

  <!-- Language toggles mobile -->
  <div class="flex gap-2 border-b py-3" style="border-color:rgba(42,191,191,0.18);">
    <span class="text-xs text-muted self-center">🌐</span>
    {(['en', 'fr', 'es', 'nl'] as const).map(l => {
      const isActive = l === lang;
      const currentPath = Astro.url.pathname
        .replace(/^\/(fr|es|nl)/, '')
        .replace(/^$/, '/');
      const href = l === 'en'
        ? (currentPath || '/')
        : `/${l}${currentPath === '/' ? '/' : currentPath}`;
      return (
        <a href={href}
           class={`px-3 py-1 rounded-full font-display font-bold text-sm border-2 min-h-[44px] flex items-center ${
             isActive
               ? 'bg-teal-DEFAULT border-teal-DEFAULT text-white pointer-events-none'
               : 'border-teal-DEFAULT text-teal-dark'
           }`}>
          {l.toUpperCase()}
        </a>
      );
    })}
  </div>

  <!-- Initiatives grouped -->
  <span class="block text-[0.68rem] font-bold tracking-[0.14em] uppercase text-teal-dark pt-4 pb-1">{t.nav.initiatives}</span>
  <a href={p('/initiatives')}
     class="block font-bold font-display text-teal-dark border-b"
     style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">
    {t.nav.allInitiatives}
  </a>

  <!-- Insights & Tools group -->
  <span class="block text-[0.62rem] font-bold tracking-[0.12em] uppercase pt-3 pb-1" style="color:#1A9A9A;">
    {lang === 'fr' ? 'Outils & Insights' : 'Insights & Tools'}
  </span>
  {items.filter((i: any) => ['YeahVibe','YeahSight','YeahDev'].includes(i.label)).map((item: any) => (
    <a href={item.href} target="_blank" rel="noopener"
       class="block pl-4 text-sm text-muted border-b"
       style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">
      {item.label} ↗
    </a>
  ))}

  <!-- Small Apps group -->
  <span class="block text-[0.62rem] font-bold tracking-[0.12em] uppercase pt-3 pb-1" style="color:#1A9A9A;">
    {lang === 'fr' ? 'Mini Applications' : 'Small Apps'}
  </span>
  {items.filter((i: any) => ['Workout','GameTrack','SpeakNote','DailyTracker'].includes(i.label)).map((item: any) => (
    <a href={item.href} target="_blank" rel="noopener"
       class="block pl-4 text-sm text-muted border-b"
       style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">
      {item.label} ↗
    </a>
  ))}

  <!-- Foundation -->
  <a href={p('/initiatives') + '#happybein'}
     class="block pl-4 text-sm text-muted border-b mt-1"
     style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">
    {lang === 'fr' ? 'Fondation HappyBein' : 'HappyBein Foundation'}
  </a>

  <!-- About -->
  <span class="block text-[0.68rem] font-bold tracking-[0.14em] uppercase text-teal-dark pt-4 pb-1">{t.nav.about}</span>
  <a href={p('/manifesto')} class="block pl-4 text-sm text-muted border-b" style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">{t.nav.manifesto}</a>
  <a href={p('/roadmap')}   class="block pl-4 text-sm text-muted border-b" style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">{t.nav.roadmap}</a>
  <a href={p('/contact')}   class="block pl-4 text-sm text-muted border-b" style="border-color:rgba(42,191,191,0.18); min-height:44px; line-height:44px;">{t.nav.contact}</a>
</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileNav?.classList.contains('hidden');
    mobileNav?.classList.toggle('hidden', isOpen);
    mobileNav?.classList.toggle('flex', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });
  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileNav.classList.add('hidden');
      mobileNav.classList.remove('flex');
      document.body.style.overflow = '';
    });
  });
</script>
