---
import { SITE } from '../data/site';
const { version, versionDate } = SITE;
---

<!-- Fixed nav -->
<nav class="fixed top-0 left-0 right-0 z-50 flex items-center"
     style="height:70px; background:rgba(255,255,255,0.97); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); border-bottom:1px solid rgba(42,191,191,0.18);">
  <div class="max-w-6xl mx-auto px-5 w-full flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0">
      <img src="/images/logo.png" alt="HappyBein" class="h-9 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center">

      <!-- Initiatives -->
      <li class="nav-item relative">
        <a href="/initiatives"
           class="flex items-center gap-1 px-4 py-2 font-display font-bold text-[0.9rem] text-ink hover:text-teal-dark transition-colors">
          Initiatives
          <span class="inline-block w-[7px] h-[7px] border-r-2 border-b-2 border-current rotate-45 translate-y-[-1px] transition-transform" style="border-color:currentColor;"></span>
        </a>
        <div class="nav-dropdown">
          {SITE.nav.initiatives.map((item, i) => (
            item.bold
              ? <a href={item.href}
                   class="block px-5 py-[0.65rem] text-sm font-bold text-teal-dark hover:bg-lightbg whitespace-nowrap">
                   All Initiatives →
                 </a>
              : <>
                  {i === 1 && <div class="h-px mx-0 my-1" style="background:rgba(42,191,191,0.18);"></div>}
                  <a href={item.href}
                     target={item.external ? '_blank' : undefined}
                     rel={item.external ? 'noopener' : undefined}
                     class="block px-5 py-[0.65rem] text-sm text-body hover:bg-lightbg hover:text-teal-dark whitespace-nowrap">
                    {item.label}{item.external ? ' ↗' : ''}
                  </a>
                </>
          ))}
        </div>
      </li>

      <!-- About -->
      <li class="nav-item relative">
        <a href="/manifesto"
           class="flex items-center gap-1 px-4 py-2 font-display font-bold text-[0.9rem] text-ink hover:text-teal-dark transition-colors">
          About
          <span class="inline-block w-[7px] h-[7px] border-r-2 border-b-2 border-current rotate-45 translate-y-[-1px]" style="border-color:currentColor;"></span>
        </a>
        <div class="nav-dropdown">
          {SITE.nav.about.map((item: any) => (
            item.divider
              ? <div class="h-px my-1" style="background:rgba(42,191,191,0.18);"></div>
              : <a href={item.href}
                   class="block px-5 py-[0.65rem] text-sm text-body hover:bg-lightbg hover:text-teal-dark whitespace-nowrap">
                   {item.label}
                 </a>
          ))}
        </div>
      </li>

    </ul>

    <!-- Hamburger -->
    <button id="hamburger" aria-label="Menu"
            class="md:hidden flex flex-col gap-[5px] p-2 bg-transparent border-none cursor-pointer"
            style="min-width:44px; min-height:44px; align-items:center; justify-content:center;">
      <span class="block w-6 h-[2px] bg-ink rounded"></span>
      <span class="block w-6 h-[2px] bg-ink rounded"></span>
      <span class="block w-6 h-[2px] bg-ink rounded"></span>
    </button>

  </div>
</nav>

<!-- Version bar -->
<div class="version-bar">
  <span class="text-teal-DEFAULT font-bold font-mono-sm">v{version}</span>
  <span style="color:rgba(255,255,255,0.15);">·</span>
  <span style="color:rgba(255,255,255,0.45);" class="font-mono-sm">{versionDate}</span>
  <span style="color:rgba(255,255,255,0.15);">·</span>
  <span style="color:rgba(255,255,255,0.45);" class="font-mono-sm">happybein.com</span>
</div>

<!-- Mobile nav -->
<div id="mobile-nav"
     class="hidden fixed left-0 right-0 bottom-0 bg-white z-40 overflow-y-auto flex-col px-6 py-4"
     style="top:calc(70px + 22px); -webkit-overflow-scrolling:touch;">

  <span class="block text-[0.68rem] font-bold tracking-[0.14em] uppercase text-teal-dark pt-4 pb-1">Initiatives</span>
  <a href="/initiatives" class="block py-3 font-bold font-display text-ink border-b min-h-[44px] leading-[44px] py-0"
     style="border-color:rgba(42,191,191,0.18); color:#1A7FAA;">All Initiatives →</a>
  {SITE.nav.initiatives.filter(i => !i.bold).map((item: any) => (
    <a href={item.href}
       target={item.external ? '_blank' : undefined}
       rel={item.external ? 'noopener' : undefined}
       class="block pl-5 text-sm text-muted border-b min-h-[44px] leading-[44px]"
       style="border-color:rgba(42,191,191,0.18);">
      {item.label}{item.external ? ' ↗' : ''}
    </a>
  ))}

  <span class="block text-[0.68rem] font-bold tracking-[0.14em] uppercase text-teal-dark pt-5 pb-1">About</span>
  {SITE.nav.about.filter((i: any) => !i.divider).map((item: any) => (
    <a href={item.href}
       class="block pl-5 text-sm text-muted border-b min-h-[44px] leading-[44px]"
       style="border-color:rgba(42,191,191,0.18);">
      {item.label}
    </a>
  ))}

</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileNav?.classList.contains('hidden');
    mobileNav?.classList.toggle('hidden', isOpen);
    mobileNav?.classList.toggle('flex', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });
  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileNav.classList.add('hidden');
      mobileNav.classList.remove('flex');
      document.body.style.overflow = '';
    });
  });
</script>
