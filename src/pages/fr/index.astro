---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/site';
import { getT } from '../../i18n/index';

const lang = 'fr';
const t = getT(lang);
const h = t.home;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "HappyBein",
      "url": SITE.url,
      "logo": `${SITE.url}/images/logo.png`,
      "foundingDate": SITE.founded,
      "description": SITE.description,
      "address": { "@type": "PostalAddress", "addressLocality": "Eindhoven", "addressCountry": "NL" },
      "contactPoint": { "@type": "ContactPoint", "email": SITE.email },
      "sameAs": Object.values(SITE.social),
    },
    { "@type": "WebSite", "url": SITE.url, "name": SITE.name },
  ]
});
---
<Base
  title={h.title}
  description={h.description}
  canonical="https://happybein.com/fr/"
  lang={lang}
  alternateEn="https://happybein.com/"
  alternateFr="https://happybein.com/fr/"
  schema={schema}
>
  <section class="max-w-6xl mx-auto px-5 grid gap-14 items-center"
           style="min-height:88vh; padding-top:4.5rem; padding-bottom:4rem; grid-template-columns:1fr 1.15fr;">
    <div>
      <h1 class="font-display font-black text-ink leading-[1.1] tracking-tight mb-5"
          style="font-size:clamp(2rem, 4vw, 3.4rem);">
        {h.heroH1a}<br/>{h.heroH1b}
      </h1>
      <p class="text-muted leading-relaxed mb-8 max-w-[400px]">{h.heroSub}</p>
      <div class="flex flex-wrap gap-3">
        <a href="https://www.yeahvibe.com" target="_blank" rel="noopener" class="btn-primary">{h.btnExplore}</a>
        <a href={lang === 'fr' ? '/fr/manifesto' : '/manifesto'} class="btn-outline">{h.btnManifesto}</a>
      </div>
    </div>
    <div class="relative rounded-xl overflow-hidden" style="aspect-ratio:16/9; background:#000; border:3px solid #2ABFBF; box-shadow:0 16px 48px rgba(26,153,154,0.15); -webkit-transform:translateZ(0); transform:translateZ(0);">
      <iframe src="https://player.vimeo.com/video/908983038?badge=0&autopause=0&player_id=0&app_id=58479"
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
              title="Introduction HappyBein"
              class="absolute inset-0 w-full h-full border-0"></iframe>
    </div>
  </section>

  <section class="py-20 px-5" style="background:#F4FAFA;">
    <div class="max-w-6xl mx-auto grid gap-12 items-center" style="grid-template-columns:1fr 1fr;">
      <div class="rounded-lg overflow-hidden" style="aspect-ratio:4/3; border:3px solid #2ABFBF; background:#E8F7F7;">
        <img src="https://happybein.com/wp-content/uploads/2022/08/shutterstock_1059887825-scaled-e1659873157592.jpg"
             alt="HappyBein" class="w-full h-full object-cover" onerror="this.style.display='none'" />
      </div>
      <div>
        <div class="section-label">{h.whatTitle}</div>
        <div class="rounded-lg p-6 mb-4" style="background:white; border-left:4px solid #2ABFBF; box-shadow:0 2px 12px rgba(26,153,154,0.12);">
          <div class="text-2xs font-bold tracking-widest uppercase text-teal-dark mb-1">{h.foundationTag}</div>
          <h3 class="font-display font-extrabold text-ink text-[1.05rem] mb-2">{h.foundationTitle}</h3>
          <p class="text-sm text-muted leading-relaxed">{h.foundationDesc} <a href={lang === 'fr' ? '/fr/manifesto' : '/manifesto'} class="text-teal-dark font-semibold border-b border-teal-dark/30">{h.foundationLink}</a></p>
        </div>
        <div class="rounded-lg p-6" style="background:white; border-left:4px solid #4CAF50; box-shadow:0 2px 12px rgba(26,153,154,0.12);">
          <div class="text-2xs font-bold tracking-widest uppercase text-green-dark mb-1">{h.platformTag}</div>
          <h3 class="font-display font-extrabold text-ink text-[1.05rem] mb-2">{h.platformTitle}</h3>
          <p class="text-sm text-muted leading-relaxed">{h.platformDesc} <a href="https://www.yeahvibe.com/" target="_blank" rel="noopener" class="text-green-dark font-semibold border-b border-green-dark/30">{h.platformLink}</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-5 text-center text-white teal-gradient">
    <div class="max-w-3xl mx-auto">
      <blockquote class="font-display font-bold leading-snug mb-4" style="font-size:clamp(1.1rem,2.2vw,1.65rem);">{h.quote}</blockquote>
      <cite class="text-xs tracking-widest uppercase opacity-75 not-italic">{h.quoteAuthor}</cite>
    </div>
  </section>

  <section class="py-20 px-5">
    <div class="max-w-6xl mx-auto">
      <div class="section-label">{lang === 'fr' ? 'Comment ça fonctionne' : 'How It Works'}</div>
      <h2 class="font-display font-extrabold text-ink tracking-tight mb-3" style="font-size:clamp(1.6rem,2.8vw,2.5rem);">{h.howTitle}</h2>
      <p class="text-muted leading-relaxed mb-10 max-w-lg">{h.howSub}</p>
      <div class="grid gap-6" style="grid-template-columns:1fr 1fr;">
        <div class="rounded-xl p-7 relative overflow-hidden" style="background:white; border:1px solid rgba(42,191,191,0.18); box-shadow:0 4px 20px rgba(26,153,154,0.12);">
          <div class="absolute top-0 left-0 right-0 h-1" style="background:#2ABFBF;"></div>
          <div class="text-2xs font-bold tracking-widest uppercase text-teal-dark mb-2">{h.streamATag}</div>
          <h3 class="font-display font-extrabold text-ink text-[1.1rem] mb-3">{h.streamATitle}</h3>
          <p class="text-sm text-muted leading-relaxed">{h.streamADesc} <span class="text-teal-dark font-semibold">{h.streamAGoal}</span></p>
        </div>
        <div class="rounded-xl p-7 relative overflow-hidden" style="background:white; border:1px solid rgba(42,191,191,0.18); box-shadow:0 4px 20px rgba(26,153,154,0.12);">
          <div class="absolute top-0 left-0 right-0 h-1" style="background:#4CAF50;"></div>
          <div class="text-2xs font-bold tracking-widest uppercase text-green-dark mb-2">{h.streamBTag}</div>
          <h3 class="font-display font-extrabold text-ink text-[1.1rem] mb-3">{h.streamBTitle}</h3>
          <p class="text-sm text-muted leading-relaxed">{h.streamBDesc} <span class="text-green-dark font-semibold">{h.streamBGoal}</span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-5 text-center" style="background:#E8F7F7;">
    <div class="teal-gradient rounded-2xl p-16 max-w-2xl mx-auto text-white" style="box-shadow:0 12px 40px rgba(42,191,191,0.2);">
      <h2 class="font-display font-extrabold leading-tight mb-4" style="font-size:clamp(1.4rem,2.5vw,2.1rem);">{h.ctaTitle}</h2>
      <p class="opacity-90 mb-8 leading-relaxed">{h.ctaDesc}</p>
      <a href={lang === 'fr' ? '/fr/contact' : '/contact'} class="btn-white">{h.ctaBtn}</a>
    </div>
  </section>
</Base>

<style>
  @media (max-width: 960px) {
    section:first-of-type { grid-template-columns: 1fr !important; min-height: auto !important; }
    .max-w-6xl > .grid { grid-template-columns: 1fr !important; }
  }
</style>
